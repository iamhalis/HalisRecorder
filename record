-- ----------------------------- LOGIC MACRO (TAB RECORD) ----------------------
local Macro = {
    Recording = false,
    Playing = false,
    Loop = false,
    Actions = {},
    StartTime = 0,
    PlayCoroutine = nil
}

local function updateUI()
    if Macro.Recording then
        statusLabel.Text = "🔴 RECORDING"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        recordBtn.BackgroundColor3 = Color3.fromRGB(220, 80, 80)
    elseif Macro.Playing then
        statusLabel.Text = Macro.Loop and "🔁 LOOPING" or "▶️ PLAYING"
        statusLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
        playOnceBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        loopBtn.BackgroundColor3 = Macro.Loop and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(100, 100, 100)
    else
        statusLabel.Text = "⚪ HalisRecorder"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        recordBtn.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
        playOnceBtn.BackgroundColor3 = Color3.fromRGB(60, 120, 200)
        loopBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
    eventCountLabel.Text = "Sự kiện: " .. #Macro.Actions
    loopLabel.Text = "Loop: " .. (Macro.Loop and "ON" or "OFF")
end

local function saveAction(input, state)
    if not Macro.Recording then return end
    local data = {
        Time = tick() - Macro.StartTime,
        KeyCode = input.KeyCode,
        UserInputType = input.UserInputType,
        State = state
    }
    table.insert(Macro.Actions, data)
    updateUI()
end

local function fireInput(action)
    if action.UserInputType == Enum.UserInputType.MouseButton1 then
        if action.State == "Begin" then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        else
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    elseif action.UserInputType == Enum.UserInputType.MouseButton2 then
        if action.State == "Begin" then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 1, true, game, 0)
        else
            VirtualInputManager:SendMouseButtonEvent(0, 0, 1, false, game, 0)
        end
    elseif action.KeyCode ~= Enum.KeyCode.Unknown then
        VirtualInputManager:SendKeyEvent(action.State == "Begin", action.KeyCode, false, game)
    end
end

function Macro:StartRecording()
    if self.Recording then return end
    if self.Playing then self:Stop() end
    self.Actions = {}
    self.StartTime = tick()
    self.Recording = true
    updateUI()
    print("[MACRO] Bắt đầu ghi")
end

function Macro:StopRecording()
    if not self.Recording then return end
    self.Recording = false
    updateUI()
    print("[MACRO] Dừng ghi - Số hành động:", #self.Actions)
end

function Macro:Play(loopMode)
    if self.Playing then self:Stop() end
    if #self.Actions == 0 then
        warn("[MACRO] Chưa có hành động nào được ghi")
        return
    end
    self.Loop = loopMode
    self.Playing = true
    updateUI()
    
    self.PlayCoroutine = task.spawn(function()
        repeat
            local previousTime = 0
            for _, action in ipairs(self.Actions) do
                if not self.Playing then break end
                local waitTime = action.Time - previousTime
                if waitTime > 0 then task.wait(waitTime) end
                if not self.Playing then break end
                fireInput(action)
                previousTime = action.Time
            end
        until not self.Loop or not self.Playing
        self.Playing = false
        updateUI()
        print("[MACRO] Kết thúc phát lại")
    end)
    print("[MACRO] Bắt đầu phát lại, loop =", self.Loop)
end

function Macro:Stop()
    if not self.Playing then return end
    self.Playing = false
    self.Loop = false
    updateUI()
    print("[MACRO] Dừng phát")
end

