-- ----------------------------- KÉO THẢ LOGO -----------------------------------
local dragging = false
local dragStartPos = nil
local logoStartPos = nil

logo.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStartPos = Vector2.new(input.Position.X, input.Position.Y)
        logoStartPos = logo.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStartPos
        logo.Position = UDim2.new(logoStartPos.X.Scale, logoStartPos.X.Offset + delta.X,
                                   logoStartPos.Y.Scale, logoStartPos.Y.Offset + delta.Y)
    end
end)

-- ----------------------------- PHÍM TẮT F1-F4 --------------------------------
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        Macro:StartRecording()
    elseif input.KeyCode == Enum.KeyCode.F2 then
        if Macro.Recording then Macro:StopRecording() elseif Macro.Playing then Macro:Stop() end
    elseif input.KeyCode == Enum.KeyCode.F3 then
        Macro:Play(false)
    elseif input.KeyCode == Enum.KeyCode.F4 then
        if Macro.Playing and Macro.Loop then Macro:Stop() else Macro:Play(true) end
    end
end)

