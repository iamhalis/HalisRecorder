        savedPosLabel.Text = string.format("Đã lưu: (%.1f, %.1f, %.1f)", pos.X, pos.Y, pos.Z)
        print("[TELEPORT] Đã lưu vị trí:", pos)
    else
        warn("Không thể lấy vị trí nhân vật")
        savedPosLabel.Text = "Lỗi: Không tìm thấy nhân vật"
    end
end)

